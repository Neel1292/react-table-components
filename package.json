{
  "name": "@neel12/react-table-components",
  "version": "1.0.0",
  "description": "A comprehensive React table component library with advanced filtering, sorting, pagination, and customizable actions",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "style": "dist/index.css",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs"
    },
    "./styles": "./dist/index.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsup",
    "dev": "tsup --watch",
    "prepublishOnly": "npm run build",
    "lint": "echo \"No linter configured\"",
    "type-check": "tsc --noEmit"
  },
  "keywords": [
    "react",
    "table",
    "data-table",
    "react-table",
    "pagination",
    "sorting",
    "filtering",
    "ui-components",
    "typescript"
  ],
  "author": "Neel Prajapati",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Neel1292/react-table-components"
  },
  "bugs": {
    "url": "https://github.com/Neel1292/react-table-components/issues"
  },
  "homepage": "https://github.com/Neel1292/react-table-components#readme",
  "dependencies": {
    "react": ">=17",
    "react-date-range": "^2.0.1",
    "react-dom": ">=17"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-date-range": "^1.4.10",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "tsup": "^8.5.1",
    "typescript": "^6.0.2"
  },
  "peerDependencies": {
    "react": ">=17",
    "react-dom": ">=17"
  }
}
